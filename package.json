{
  "name": "ai-resume-copilot",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered resume generator and optimizer",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/worker\" \"npm run dev --workspace=apps/web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.3",
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
